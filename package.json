{
  "name": "misfit-ministries-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Misfit Ministries — Nura Platform (Express 5 + MySQL)",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @workspace/api-server dev & pnpm --filter @workspace/misfit dev",
    "build": "pnpm --filter @workspace/db build && pnpm --filter @workspace/api-server build && pnpm --filter @workspace/misfit build",
    "test": "pnpm --filter @workspace/api-server test && pnpm --filter @workspace/misfit test",
    "lint": "pnpm --filter @workspace/api-server lint && pnpm --filter @workspace/misfit lint",
    "db:push": "pnpm --filter @workspace/db db:push",
    "db:generate": "pnpm --filter @workspace/db db:generate"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react-router-dom": "^7.15.1"
  }
}
